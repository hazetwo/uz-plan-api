[
    {
        "label": "Run python server",
        "command": "uv",
        "args": [
            "run",
            "hypercorn",
            "app.main:app",
            "--reload",
            "--log-level",
            "info",
            "--bind",
            "0.0.0.0:8000",
        ],
        "use_new_terminal": false,
        "allow_concurrent_runs": false,
        "reveal": "always",
    },
    {
        "label": "pytest current file (-s)",
        "command": "pytest",
        "args": ["-s", "$ZED_FILE"],
        "use_new_terminal": false,
        "allow_concurrent_runs": false,
    },
]
